# ──────────────────────────────────────────────────────────────────────────────
# Velora Trading Platform — Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────

# -- Application Settings --
ENVIRONMENT=development
# JWT secret for authentication
JWT_SECRET_KEY=change_this_to_a_long_random_string_for_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# -- Database --
# SQLite locally, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///velora.db
# Uncomment for production
# DATABASE_URL=postgresql+asyncpg://velora:velora_pass@localhost:5432/velora_db
# DB_USER=velora
# DB_PASSWORD=velora_pass
# DB_NAME=velora_db

# -- Frontend / Backend URLs --
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
MOBILE_API_URL=http://localhost:5050
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MOBILE_API_URL=http://localhost:5050

# -- AI Agent --
NVIDIA_NIM_API_KEY=nvapi-your_key_here
NVIDIA_MODEL_NAME=meta/llama-3.1-405b-instruct
KIMI_API_KEY=your_kimi_key_here

# -- MT5 Credentials (Optional, loaded via UI if empty) --
MT5_ACCOUNT=1234567
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo
